generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String                   @unique
  logoUrl                 String?
  type                    BusinessType             @default(SHOP)
  institutionType         String?
  plan                    SubscriptionPlan         @default(FREE)
  status                  String                   @default("PENDING")
  trialStartDate          DateTime?                @default(now())
  trialEndDate            DateTime?
  enabledModules          String[]                 @default([])
  currency                String                   @default("SLL")
  timezone                String                   @default("UTC")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  registrationReceipt     String?
  address                 String?
  email                   String?
  phone                   String?
  flutterwaveRef          String?
  subscriptionStatus      String                   @default("INACTIVE")
  requestedBillingPeriod  String                   @default("monthly")
  attendance              Attendance[]
  auditLogs               AuditLog[]
  batches                 Batch[]
  categories              Category[]
  customers               Customer[]
  debts                   Debt[]
  expenses                Expense[]
  invoices                Invoice[]
  loyaltyCampaigns        LoyaltyCampaign[]
  loyaltyTiers            LoyaltyTier[]
  notifications           Notification[]
  orderStatusHistory      OrderStatusHistory[]
  payments                Payment[]
  payrolls                Payroll[]
  products                Product[]
  purchases               Purchase[]
  purchaseItems           PurchaseItem[]
  restaurantTables        RestaurantTable[]
  roles                   Role[]
  sales                   Sale[]
  saleItems               SaleItem[]
  salesOrders             SalesOrder[]
  salesOrderItems         SalesOrderItem[]
  stockMovements          StockMovement[]
  subscriptions           Subscription[]
  suppliers               Supplier[]
  users                   User[]
  pushSubscriptions       PushSubscription[]
  patients                Patient[]
  prescriptions           Prescription[]
  locations               Location[]
  appointments            Appointment[]
  consultations           Consultation[]
  labTests                LabTest[]
  salesDrafts             SalesDraft[]
  schoolStudents          SchoolStudent[]
  schoolCourses           SchoolCourse[]
  schoolEnrollments       SchoolEnrollment[]
  schoolAttendance        SchoolAttendance[]
  schoolPayments          SchoolPayment[]
  schoolLibraryBooks      SchoolLibraryBook[]
  schoolBookCheckouts     SchoolBookCheckout[]
  schoolHostels           SchoolHostel[]
  schoolHostelAllocations SchoolHostelAllocation[]
  schoolBroadcasts        SchoolBroadcast[]
  schoolInvoices          SchoolInvoice[]
  schoolTerms             SchoolTerm[]
  schoolGrades            SchoolGrade[]
  schoolStaffs            SchoolStaff[]
  schoolLeaveRequests     SchoolLeaveRequest[]
  schoolPayslips          SchoolPayslip[]
  quotes                  Quote[]

  @@index([slug])
}

model User {
  id                      String                    @id @default(cuid())
  name                    String?
  username                String?                   @unique
  email                   String                    @unique
  passwordHash            String
  status                  String                    @default("active")
  businessId              String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?
  roleId                  String
  specialization          String?
  phone                   String?
  department              String?
  jobTitle                String?
  imageUrl                String?
  hourlyRate              Decimal?                  @db.Decimal(10, 2)
  salary                  Decimal?                  @db.Decimal(10, 2)
  emailVerified           DateTime?
  verificationToken       String?
  attendance              Attendance[]
  auditLogs               AuditLog[]
  expenses                Expense[]
  orderStatusHistory      OrderStatusHistory[]
  payrolls                Payroll[]
  purchases               Purchase[]
  sales                   Sale[]
  assignedSales           Sale[]                    @relation("StaffSale")
  stockMovements          StockMovement[]
  salesOrders             SalesOrder[]
  salesOrderStatusHistory SalesOrderStatusHistory[]
  business                Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role                    Role                      @relation(fields: [roleId], references: [id])
  appointments            Appointment[]
  consultations           Consultation[]
  labTests                LabTest[]                 @relation("LabTechnician")
  requestedLabTests       LabTest[]                 @relation("DoctorLabTests")
  salesDrafts             SalesDraft[]

  @@index([businessId])
  @@index([roleId])
  @@index([verificationToken])
}

model Attendance {
  id         String    @id @default(cuid())
  userId     String
  businessId String
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  status     String    @default("PRESENT")
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Payroll {
  id            String    @id @default(cuid())
  userId        String
  businessId    String
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING")
  periodStart   DateTime
  periodEnd     DateTime
  paymentDate   DateTime?
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  businessId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business?    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[] @relation("PermissionToRole")

  @@unique([businessId, name])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  roles Role[] @relation("PermissionToRole")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  businessId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Product {
  id                    String           @id @default(cuid())
  name                  String
  sku                   String?
  description           String?
  barcode               String?
  unitPrice             Decimal          @db.Decimal(10, 2)
  costPrice             Decimal?         @db.Decimal(10, 2)
  stockQuantity         Decimal          @default(0) @db.Decimal(10, 2)
  minStockLevel         Int              @default(10)
  status                String           @default("active")
  metadata              Json?
  businessId            String
  categoryId            String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  isNetworkAvailable    Boolean          @default(false)
  requiresPrescription  Boolean          @default(false)
  genericAlternative    String?
  isControlledSubstance Boolean          @default(false)
  originalBusinessId    String?
  originalProductId     String?
  type                  ProductType      @default(PRODUCT)
  imageUrl              String?
  baseUnit              String           @default("Unit")
  batches               Batch[]
  business              Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category              Category?        @relation(fields: [categoryId], references: [id])
  units                 ProductUnit[]
  purchaseItems         PurchaseItem[]
  saleItems             SaleItem[]
  salesOrderItems       SalesOrderItem[]
  stockMovements        StockMovement[]
  locationStocks        LocationStock[]
  transfers             StockTransfer[]
  invoiceItems          InvoiceItem[]
  quoteItems            QuoteItem[]

  @@index([businessId, sku])
  @@index([businessId, deletedAt])
  @@index([isNetworkAvailable])
}

model ProductUnit {
  id           String   @id @default(cuid())
  productId    String
  name         String
  ratio        Decimal  @db.Decimal(10, 4)
  sellingPrice Decimal  @db.Decimal(10, 2)
  costPrice    Decimal? @db.Decimal(10, 2)
  barcode      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Batch {
  id                String    @id @default(cuid())
  productId         String
  batchNumber       String
  quantity          Int       @default(0)
  manufacturingDate DateTime?
  expiryDate        DateTime?
  businessId        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@index([businessId, expiryDate])
}

model RestaurantTable {
  id         String    @id @default(cuid())
  name       String
  capacity   Int       @default(4)
  status     String    @default("available")
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Customer {
  id          String       @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  businessId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  debts       Debt[]
  sales       Sale[]
  salesDrafts SalesDraft[]
  invoices    Invoice[]
  salesOrders SalesOrder[]
  quotes      Quote[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Sale {
  id            String               @id @default(cuid())
  invoiceNumber String               @unique
  totalAmount   Decimal              @db.Decimal(10, 2)
  discount      Decimal              @default(0) @db.Decimal(10, 2)
  tax           Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod String               @default("CASH")
  paymentStatus String               @default("PAID")
  status        String               @default("COMPLETED")
  businessId    String
  userId        String
  customerId    String?
  patientId     String?
  tableId       String?
  staffId       String?
  staffName     String?
  createdAt     DateTime             @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime             @updatedAt
  debt          Debt?
  statusHistory OrderStatusHistory[]
  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?            @relation(fields: [customerId], references: [id])
  patient       Patient?             @relation(fields: [patientId], references: [id])
  table         RestaurantTable?     @relation(fields: [tableId], references: [id])
  user          User                 @relation(fields: [userId], references: [id])
  staff         User?                @relation("StaffSale", fields: [staffId], references: [id])
  items         SaleItem[]
  consultation  Consultation?        @relation("ConsultationSale")
  labTest       LabTest?             @relation("LabTestSale")
  prescription  Prescription?        @relation("PrescriptionSale")
  tags          TransactionTag[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

// ─────────────────────────────────────────────────────────────────
// SALES ORDER MODELS (distinct from Sale/Invoice)
// A SalesOrder is created when a customer places an order.
// It reserves stock and can be edited before fulfillment.
// Once delivered, it can be converted to a Sale (Invoice).
// ─────────────────────────────────────────────────────────────────

model SalesOrder {
  id              String    @id @default(cuid())
  soNumber        String    @unique // e.g. SO-000045
  orderDate       DateTime  @default(now())
  expectedDate    DateTime?
  customerName    String
  customerEmail   String?
  customerPhone   String?
  deliveryAddress String?
  billingAddress  String?
  paymentTerms    String    @default("Due on Receipt")
  deliveryMethod  String? // e.g. Pickup, Standard Delivery, Express
  notes           String?
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  tax             Decimal   @default(0) @db.Decimal(10, 2)
  subtotal        Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  status          String    @default("DRAFT")
  // Status workflow: DRAFT → PENDING → CONFIRMED → PROCESSING → SHIPPED → DELIVERED → COMPLETED
  // Any non-COMPLETED status can go to: CANCELLED
  convertedSaleId String? // Set when this SO is converted to an invoice/sale
  businessId      String
  userId          String
  customerId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User                      @relation(fields: [userId], references: [id])
  customer      Customer?                 @relation(fields: [customerId], references: [id])
  items         SalesOrderItem[]
  statusHistory SalesOrderStatusHistory[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, deletedAt])
  @@index([soNumber])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String?
  productName  String
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)
  businessId   String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])
  business   Business?  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
  @@index([businessId])
}

model SalesOrderStatusHistory {
  id           String   @id @default(cuid())
  salesOrderId String
  status       String
  note         String?
  userId       String
  createdAt    DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([salesOrderId])
}

model OrderStatusHistory {
  id         String    @id @default(cuid())
  saleId     String
  status     String
  note       String?
  userId     String
  createdAt  DateTime  @default(now())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([saleId])
  @@index([businessId])
}

model SaleItem {
  id                 String    @id @default(cuid())
  saleId             String
  productId          String?
  quantity           Int
  unitPrice          Decimal   @db.Decimal(10, 2)
  total              Decimal   @db.Decimal(10, 2)
  status             String    @default("pending")
  externalCostPrice  Decimal?  @db.Decimal(10, 2)
  externalSourceName String?
  isExternalSourced  Boolean   @default(false)
  productName        String?
  businessId         String?
  business           Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product            Product?  @relation(fields: [productId], references: [id])
  sale               Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Supplier {
  id         String     @id @default(cuid())
  name       String
  contact    String?
  email      String?
  phone      String?
  businessId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  purchases  Purchase[]
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Purchase {
  id            String         @id @default(cuid())
  invoiceNumber String?
  totalAmount   Decimal        @db.Decimal(10, 2)
  status        String         @default("COMPLETED")
  supplierId    String?
  businessId    String
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  items         PurchaseItem[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model PurchaseItem {
  id         String    @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Decimal   @db.Decimal(10, 2)
  total      Decimal   @db.Decimal(10, 2)
  businessId String?
  unitId     String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model StockMovement {
  id         String            @id @default(cuid())
  productId  String
  quantity   Int
  type       StockMovementType
  reason     String?
  businessId String
  userId     String
  createdAt  DateTime          @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime          @updatedAt
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])

  @@index([businessId, productId])
  @@index([businessId, deletedAt])
}

model Debt {
  id          String        @id @default(cuid())
  customerId  String
  saleId      String?       @unique
  totalAmount Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  dueDate     DateTime?
  status      String        @default("PENDING")
  businessId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale        Sale?         @relation(fields: [saleId], references: [id])
  payments    DebtPayment[]

  @@index([businessId, customerId])
  @@index([businessId, deletedAt])
}

model DebtPayment {
  id            String    @id @default(cuid())
  debtId        String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @default("CASH")
  businessId    String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime  @updatedAt
  note          String?
  debt          Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([businessId, deletedAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  userId     String
  businessId String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([businessId])
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  message    String
  type       String    @default("INFO")
  isRead     Boolean   @default(false)
  businessId String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Subscription {
  id         String           @id @default(cuid())
  businessId String
  plan       SubscriptionPlan
  status     String           @default("active")
  startDate  DateTime         @default(now())
  endDate    DateTime
  amount     Decimal          @db.Decimal(10, 2)
  currency   String           @default("SLL")
  paymentRef String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyTier {
  id         String   @id @default(cuid())
  name       String
  multiplier Float
  discount   Float
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyCampaign {
  id            String   @id @default(cuid())
  name          String
  targetCluster String
  status        String   @default("DRAFT")
  businessId    String
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String    @id @default(cuid())
  invoiceNumber  String    @unique
  businessId     String
  customerId     String?
  issueDate      DateTime  @default(now())
  dueDate        DateTime
  subTotal       Decimal   @default(0) @db.Decimal(10, 2)
  taxRate        Decimal   @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(10, 2)
  discountAmount Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal   @default(0) @db.Decimal(10, 2)
  balanceDue     Decimal   @default(0) @db.Decimal(10, 2)
  status         String    @default("DRAFT") // DRAFT, UNPAID, PARTIAL, PAID, OVERDUE, CANCELLED
  notes          String?   @db.Text
  terms          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([businessId])
  @@index([customerId])
  @@index([businessId, deletedAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id            String    @id @default(cuid())
  businessId    String
  invoiceId     String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String
  paymentRef    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Expense {
  id            String    @id @default(cuid())
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  category      String
  date          DateTime  @default(now())
  paymentMethod String    @default("CASH")
  businessId    String
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  tags          TransactionTag[]

  @@index([businessId])
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum BusinessType {
  SHOP
  RESTAURANT
  BAR
  PHARMACY
  SUPERMARKET
  CLINIC
  HOSPITAL
  OFFICE
  SCHOOL
}

enum SubscriptionPlan {
  FREE
  BASIC
  STANDARD
  BUSINESS
  ENTERPRISE
}

model PushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  keysAuth   String
  keysP256dh String
  businessId String
  userId     String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Patient {
  id                 String         @id @default(cuid())
  name               String
  dateOfBirth        DateTime?
  gender             String?
  phone              String?
  email              String?
  address            String?
  allergies          String?
  medicalNotes       String?
  nationality        String?
  emergencyContact   String?
  conditions         String?
  pastProcedures     String?
  currentMedications String?
  immunizations      String?
  businessId         String
  business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  prescriptions      Prescription[]
  appointments       Appointment[]
  consultations      Consultation[]
  labTests           LabTest[]
  sales              Sale[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([businessId])
}

model Prescription {
  id                 String   @id @default(cuid())
  prescriptionNumber String   @unique
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorName         String
  dateIssued         DateTime @default(now())
  status             String   @default("PENDING") // PENDING, DISPENSED, CANCELLED
  notes              String?
  instructions       String? // e.g. "Take 1 tablet after meals"
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId             String?  @unique
  sale               Sale?    @relation("PrescriptionSale", fields: [saleId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([businessId])
  @@index([patientId])
}

model Location {
  id            String          @id @default(cuid())
  name          String
  type          String          @default("STORE") // STORE, WAREHOUSE, OUTLET
  address       String?
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stocks        LocationStock[]
  transfersFrom StockTransfer[] @relation("TransfersFrom")
  transfersTo   StockTransfer[] @relation("TransfersTo")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([businessId])
}

model LocationStock {
  id         String   @id @default(cuid())
  locationId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 2)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([locationId, productId])
  @@index([locationId])
  @@index([productId])
}

model StockTransfer {
  id             String   @id @default(cuid())
  fromLocationId String
  toLocationId   String
  productId      String
  quantity       Decimal  @db.Decimal(10, 2)
  status         String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  fromLocation   Location @relation("TransfersFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation     Location @relation("TransfersTo", fields: [toLocationId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([productId])
}

model Appointment {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          User          @relation(fields: [doctorId], references: [id])
  appointmentDate DateTime
  status          String        @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  reason          String?
  notes           String?
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  consultation    Consultation?

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model Consultation {
  id             String       @id @default(cuid())
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         User         @relation(fields: [doctorId], references: [id])
  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  vitals         Json? // { bp, temp, weight, heartRate, etc. }
  chiefComplaint String?
  symptoms       String?
  diagnosis      String?
  treatmentPlan  String?
  doctorNotes    String?      @db.Text
  businessId     String
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId         String?      @unique
  sale           Sale?        @relation("ConsultationSale", fields: [saleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  labTests       LabTest[]

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model LabTest {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          User          @relation("DoctorLabTests", fields: [doctorId], references: [id])
  consultationId  String?
  consultation    Consultation? @relation(fields: [consultationId], references: [id])
  testName        String
  testCategory    String?
  results         String?       @db.Text
  status          String        @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  labTechnicianId String?
  labTechnician   User?         @relation("LabTechnician", fields: [labTechnicianId], references: [id])
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId          String?       @unique
  sale            Sale?         @relation("LabTestSale", fields: [saleId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model SalesDraft {
  id            String    @id @default(cuid())
  draftNumber   String    @unique
  businessId    String
  userId        String
  customerId    String?
  customerName  String?
  customerPhone String?
  items         Json
  totalAmount   Decimal   @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([userId])
}

model SystemSetting {
  id                          String   @id @default("singleton")
  registrationOpen            Boolean  @default(true)
  defaultTrialDays            Int      @default(7)
  announcementBanner          String   @default("")
  announcementBannerUpdatedAt String   @default("")
  emailAlertsEnabled          Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model SchoolStudent {
  id                String    @id @default(cuid())
  businessId        String
  studentId         String
  firstName         String
  lastName          String
  gender            String
  dateOfBirth       DateTime?
  address           String?
  phone             String?
  email             String?
  photoPath         String?
  guardianName      String?
  guardianPhone     String?
  guardianEmail     String?
  guardianRelation  String?
  bloodGroup        String?
  medicalConditions String?
  currentLevel      String?
  enrollmentDate    DateTime  @default(now())
  status            String    @default("ACTIVE")
  applicationSource String    @default("ONLINE")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business                  Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enrollments               SchoolEnrollment[]
  attendance                SchoolAttendance[]
  payments                  SchoolPayment[]
  schoolBookCheckouts       SchoolBookCheckout[]
  schoolHostelAllocations   SchoolHostelAllocation[]
  schoolBroadcastRecipients SchoolBroadcastRecipient[]
  schoolInvoices            SchoolInvoice[]
  schoolGrades              SchoolGrade[]

  @@unique([businessId, studentId])
  @@index([businessId])
}

model SchoolCourse {
  id          String   @id @default(cuid())
  businessId  String
  courseName  String
  courseCode  String
  description String?
  duration    String
  fee         Decimal  @db.Decimal(10, 2)
  schedule    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enrollments  SchoolEnrollment[]
  attendance   SchoolAttendance[]
  payments     SchoolPayment[]
  schoolGrades SchoolGrade[]

  @@unique([businessId, courseCode])
  @@index([businessId])
}

model SchoolEnrollment {
  id             String    @id @default(cuid())
  businessId     String
  studentId      String
  courseId       String
  enrollmentDate DateTime  @default(now())
  completionDate DateTime?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  student  SchoolStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course   SchoolCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([businessId])
  @@index([studentId])
  @@index([courseId])
}

model SchoolAttendance {
  id         String   @id @default(cuid())
  businessId String
  studentId  String
  courseId   String
  date       DateTime
  status     String   @default("PRESENT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  student  SchoolStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course   SchoolCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
  @@index([businessId])
  @@index([studentId])
  @@index([courseId])
}

model SchoolPayment {
  id               String   @id @default(cuid())
  businessId       String
  studentId        String
  courseId         String?
  amount           Decimal  @db.Decimal(10, 2)
  paymentDate      DateTime
  paymentMethod    String?
  status           String   @default("PAID")
  receiptNumber    String?  @unique
  formType         String?
  paymentReference String? // External reference (e.g., mobile money transaction ID)
  guardianName     String? // For registration form
  guardianPhone    String? // For registration form
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  student  SchoolStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course   SchoolCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   SchoolInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([studentId])
  @@index([courseId])
}

// -----------------------------------------
// PHASE 3: LIBRARY & HOSTEL MANAGEMENT
// -----------------------------------------

model SchoolLibraryBook {
  id              String   @id @default(cuid())
  businessId      String
  title           String
  author          String?
  isbn            String?
  category        String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business  Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  checkouts SchoolBookCheckout[]

  @@index([businessId])
}

model SchoolBookCheckout {
  id           String    @id @default(cuid())
  businessId   String
  bookId       String
  studentId    String
  checkoutDate DateTime  @default(now())
  dueDate      DateTime
  returnDate   DateTime?
  status       String    @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  book     SchoolLibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student  SchoolStudent     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([studentId])
  @@index([bookId])
}

model SchoolHostel {
  id         String   @id @default(cuid())
  businessId String
  blockName  String
  roomNumber String
  capacity   Int      @default(1)
  type       String? // BOYS, GIRLS, MIXED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business    Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  allocations SchoolHostelAllocation[]

  @@unique([businessId, blockName, roomNumber])
  @@index([businessId])
}

model SchoolHostelAllocation {
  id             String   @id @default(cuid())
  businessId     String
  hostelId       String
  studentId      String
  allocationDate DateTime @default(now())
  status         String   @default("ACTIVE") // ACTIVE, VACATED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  hostel   SchoolHostel  @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  student  SchoolStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([studentId])
  @@index([hostelId])
}

// -----------------------------------------
// PHASE 4: COMMUNICATION HUB
// -----------------------------------------

model SchoolBroadcast {
  id         String    @id @default(cuid())
  businessId String
  subject    String
  content    String
  channel    String // EMAIL, SMS, WHATSAPP, IN_APP
  audience   String // ALL_STUDENTS, SPECIFIC_COURSE, etc.
  status     String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business   Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  recipients SchoolBroadcastRecipient[]

  @@index([businessId])
}

model SchoolBroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  studentId   String
  status      String    @default("PENDING") // PENDING, DELIVERED, FAILED
  errorReason String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  broadcast SchoolBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  student   SchoolStudent   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([studentId])
}

// -----------------------------------------
// PHASE 5: FINANCE & ACADEMICS
// -----------------------------------------

model SchoolInvoice {
  id          String   @id @default(cuid())
  businessId  String
  studentId   String
  title       String // e.g. "Term 1 Tuition 2026"
  description String?
  totalAmount Decimal  @db.Decimal(10, 2)
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING, PARTIAL, PAID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  student  SchoolStudent   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments SchoolPayment[]

  @@index([businessId])
  @@index([studentId])
}

model SchoolTerm {
  id         String   @id @default(cuid())
  businessId String
  name       String // e.g. "First Term 2026"
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  grades   SchoolGrade[]

  @@index([businessId])
}

model SchoolGrade {
  id         String   @id @default(cuid())
  businessId String
  studentId  String
  courseId   String
  termId     String
  score      Decimal  @db.Decimal(5, 2) // E.g., 95.50
  grade      String? // E.g., "A", "B"
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  student  SchoolStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course   SchoolCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term     SchoolTerm    @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, termId])
  @@index([businessId])
  @@index([studentId])
  @@index([courseId])
  @@index([termId])
}

// -----------------------------------------
// PHASE 6: STAFF & HR MANAGEMENT
// -----------------------------------------

model SchoolStaff {
  id         String   @id @default(cuid())
  businessId String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       String // e.g. "Teacher", "Admin", "Bursar"
  department String?
  salary     Decimal  @db.Decimal(10, 2)
  hireDate   DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leaveRequests SchoolLeaveRequest[]
  payslips      SchoolPayslip[]

  @@index([businessId])
}

model SchoolLeaveRequest {
  id         String   @id @default(cuid())
  businessId String
  staffId    String
  leaveType  String // e.g. "Sick", "Vacation", "Maternity"
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    SchoolStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([staffId])
}

model SchoolPayslip {
  id          String    @id @default(cuid())
  businessId  String
  staffId     String
  month       String // e.g. "October 2026"
  baseSalary  Decimal   @db.Decimal(10, 2)
  deductions  Decimal   @default(0) @db.Decimal(10, 2)
  bonuses     Decimal   @default(0) @db.Decimal(10, 2)
  netPay      Decimal   @db.Decimal(10, 2)
  status      String    @default("PENDING") // PENDING, PAID
  paymentDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    SchoolStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([staffId])
}

model Quote {
  id          String      @id @default(cuid())
  reference   String // e.g., QT-001, removed @unique to allow scoping by business or just rely on cuid
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  status      QuoteStatus @default(DRAFT) // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  totalAmount Decimal     @db.Decimal(10, 2)
  notes       String?
  validUntil  DateTime?
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items       QuoteItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([businessId, reference])
  @@index([businessId])
  @@index([customerId])
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  amount    Decimal @db.Decimal(10, 2)

  @@index([quoteId])
  @@index([productId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                     String               @id @default(cuid())
  name                   String
  slug                   String               @unique
  logoUrl                String?
  type                   BusinessType         @default(SHOP)
  plan                   SubscriptionPlan     @default(FREE)
  status                 String               @default("PENDING")
  trialStartDate         DateTime?            @default(now())
  trialEndDate           DateTime?
  enabledModules         String[]             @default([])
  currency               String               @default("SLL")
  timezone               String               @default("UTC")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  registrationReceipt    String?
  address                String?
  email                  String?
  phone                  String?
  flutterwaveRef         String?
  subscriptionStatus     String               @default("INACTIVE")
  requestedBillingPeriod String               @default("monthly")
  attendance             Attendance[]
  auditLogs              AuditLog[]
  batches                Batch[]
  categories             Category[]
  customers              Customer[]
  debts                  Debt[]
  expenses               Expense[]
  invoices               Invoice[]
  loyaltyCampaigns       LoyaltyCampaign[]
  loyaltyTiers           LoyaltyTier[]
  notifications          Notification[]
  orderStatusHistory     OrderStatusHistory[]
  payments               Payment[]
  payrolls               Payroll[]
  products               Product[]
  purchases              Purchase[]
  purchaseItems          PurchaseItem[]
  restaurantTables       RestaurantTable[]
  roles                  Role[]
  sales                  Sale[]
  saleItems              SaleItem[]
  stockMovements         StockMovement[]
  subscriptions          Subscription[]
  suppliers              Supplier[]
  users                  User[]
  pushSubscriptions      PushSubscription[]
  patients               Patient[]
  prescriptions          Prescription[]
  locations              Location[]
  appointments           Appointment[]
  consultations          Consultation[]
  labTests               LabTest[]
  salesDrafts            SalesDraft[]

  @@index([slug])
}

model User {
  id                 String               @id @default(cuid())
  name               String?
  username           String?              @unique
  email              String               @unique
  passwordHash       String
  status             String               @default("active")
  businessId         String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?
  roleId             String
  specialization     String?
  hourlyRate         Decimal?             @db.Decimal(10, 2)
  salary             Decimal?             @db.Decimal(10, 2)
  emailVerified      DateTime?
  verificationToken  String?
  attendance         Attendance[]
  auditLogs          AuditLog[]
  expenses           Expense[]
  orderStatusHistory OrderStatusHistory[]
  payrolls           Payroll[]
  purchases          Purchase[]
  sales              Sale[]
  stockMovements     StockMovement[]
  business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role               Role                 @relation(fields: [roleId], references: [id])
  appointments       Appointment[]
  consultations      Consultation[]
  labTests           LabTest[]            @relation("LabTechnician")
  requestedLabTests  LabTest[]            @relation("DoctorLabTests")
  salesDrafts        SalesDraft[]

  @@index([businessId])
  @@index([roleId])
  @@index([verificationToken])
}

model Attendance {
  id         String    @id @default(cuid())
  userId     String
  businessId String
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  status     String    @default("PRESENT")
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Payroll {
  id            String    @id @default(cuid())
  userId        String
  businessId    String
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING")
  periodStart   DateTime
  periodEnd     DateTime
  paymentDate   DateTime?
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  businessId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business?    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[] @relation("PermissionToRole")

  @@unique([businessId, name])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  roles Role[] @relation("PermissionToRole")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  businessId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Product {
  id                    String          @id @default(cuid())
  name                  String
  sku                   String?
  description           String?
  barcode               String?
  unitPrice             Decimal         @db.Decimal(10, 2)
  costPrice             Decimal?        @db.Decimal(10, 2)
  stockQuantity         Decimal         @default(0) @db.Decimal(10, 2)
  minStockLevel         Int             @default(10)
  status                String          @default("active")
  metadata              Json?
  businessId            String
  categoryId            String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  isNetworkAvailable    Boolean         @default(false)
  requiresPrescription  Boolean         @default(false)
  genericAlternative    String?
  isControlledSubstance Boolean         @default(false)
  originalBusinessId    String?
  originalProductId     String?
  type                  ProductType     @default(PRODUCT)
  imageUrl              String?
  baseUnit              String          @default("Unit")
  batches               Batch[]
  business              Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category              Category?       @relation(fields: [categoryId], references: [id])
  units                 ProductUnit[]
  purchaseItems         PurchaseItem[]
  saleItems             SaleItem[]
  stockMovements        StockMovement[]
  locationStocks        LocationStock[]
  transfers             StockTransfer[]

  @@index([businessId, sku])
  @@index([businessId, deletedAt])
  @@index([isNetworkAvailable])
}

model ProductUnit {
  id           String   @id @default(cuid())
  productId    String
  name         String
  ratio        Decimal  @db.Decimal(10, 4)
  sellingPrice Decimal  @db.Decimal(10, 2)
  costPrice    Decimal? @db.Decimal(10, 2)
  barcode      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Batch {
  id                String    @id @default(cuid())
  productId         String
  batchNumber       String
  quantity          Int       @default(0)
  manufacturingDate DateTime?
  expiryDate        DateTime?
  businessId        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@index([businessId, expiryDate])
}

model RestaurantTable {
  id         String    @id @default(cuid())
  name       String
  capacity   Int       @default(4)
  status     String    @default("available")
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  debts      Debt[]
  sales      Sale[]
  salesDrafts SalesDraft[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Sale {
  id            String               @id @default(cuid())
  invoiceNumber String               @unique
  totalAmount   Decimal              @db.Decimal(10, 2)
  discount      Decimal              @default(0) @db.Decimal(10, 2)
  tax           Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod String               @default("CASH")
  paymentStatus String               @default("PAID")
  status        String               @default("COMPLETED")
  businessId    String
  userId        String
  customerId    String?
  patientId     String?
  tableId       String?
  createdAt     DateTime             @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime             @updatedAt
  debt          Debt?
  statusHistory OrderStatusHistory[]
  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?            @relation(fields: [customerId], references: [id])
  patient       Patient?             @relation(fields: [patientId], references: [id])
  table         RestaurantTable?     @relation(fields: [tableId], references: [id])
  user          User                 @relation(fields: [userId], references: [id])
  items         SaleItem[]
  consultation  Consultation?        @relation("ConsultationSale")
  labTest       LabTest?             @relation("LabTestSale")
  prescription  Prescription?        @relation("PrescriptionSale")

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model OrderStatusHistory {
  id         String    @id @default(cuid())
  saleId     String
  status     String
  note       String?
  userId     String
  createdAt  DateTime  @default(now())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([saleId])
  @@index([businessId])
}

model SaleItem {
  id                 String    @id @default(cuid())
  saleId             String
  productId          String?
  quantity           Int
  unitPrice          Decimal   @db.Decimal(10, 2)
  total              Decimal   @db.Decimal(10, 2)
  status             String    @default("pending")
  externalCostPrice  Decimal?  @db.Decimal(10, 2)
  externalSourceName String?
  isExternalSourced  Boolean   @default(false)
  productName        String?
  businessId         String?
  business           Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product            Product?  @relation(fields: [productId], references: [id])
  sale               Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Supplier {
  id         String     @id @default(cuid())
  name       String
  contact    String?
  email      String?
  phone      String?
  businessId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  purchases  Purchase[]
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Purchase {
  id            String         @id @default(cuid())
  invoiceNumber String?
  totalAmount   Decimal        @db.Decimal(10, 2)
  status        String         @default("COMPLETED")
  supplierId    String?
  businessId    String
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  items         PurchaseItem[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model PurchaseItem {
  id         String    @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Decimal   @db.Decimal(10, 2)
  total      Decimal   @db.Decimal(10, 2)
  businessId String?
  unitId     String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model StockMovement {
  id         String            @id @default(cuid())
  productId  String
  quantity   Int
  type       StockMovementType
  reason     String?
  businessId String
  userId     String
  createdAt  DateTime          @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime          @updatedAt
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])

  @@index([businessId, productId])
  @@index([businessId, deletedAt])
}

model Debt {
  id          String        @id @default(cuid())
  customerId  String
  saleId      String?       @unique
  totalAmount Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  dueDate     DateTime?
  status      String        @default("PENDING")
  businessId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale        Sale?         @relation(fields: [saleId], references: [id])
  payments    DebtPayment[]

  @@index([businessId, customerId])
  @@index([businessId, deletedAt])
}

model DebtPayment {
  id            String    @id @default(cuid())
  debtId        String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @default("CASH")
  businessId    String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime  @updatedAt
  note          String?
  debt          Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([businessId, deletedAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  userId     String
  businessId String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([businessId])
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  message    String
  type       String    @default("INFO")
  isRead     Boolean   @default(false)
  businessId String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Subscription {
  id         String           @id @default(cuid())
  businessId String
  plan       SubscriptionPlan
  status     String           @default("active")
  startDate  DateTime         @default(now())
  endDate    DateTime
  amount     Decimal          @db.Decimal(10, 2)
  currency   String           @default("SLL")
  paymentRef String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyTier {
  id         String   @id @default(cuid())
  name       String
  multiplier Float
  discount   Float
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyCampaign {
  id            String   @id @default(cuid())
  name          String
  targetCluster String
  status        String   @default("DRAFT")
  businessId    String
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String    @id @default(cuid())
  businessId String
  amount     Decimal   @db.Decimal(10, 2)
  status     String    @default("UNPAID")
  dueDate    DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Payment {
  id            String    @id @default(cuid())
  businessId    String
  invoiceId     String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String
  paymentRef    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Expense {
  id            String    @id @default(cuid())
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  category      String
  date          DateTime  @default(now())
  paymentMethod String    @default("CASH")
  businessId    String
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])

  @@index([businessId])
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum BusinessType {
  SHOP
  RESTAURANT
  BAR
  PHARMACY
  SUPERMARKET
  CLINIC
  HOSPITAL
}

enum SubscriptionPlan {
  FREE
  BASIC
  STANDARD
  BUSINESS
  ENTERPRISE
}

model PushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  keysAuth   String
  keysP256dh String
  businessId String
  userId     String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Patient {
  id            String         @id @default(cuid())
  name          String
  dateOfBirth   DateTime?
  gender        String?
  phone         String?
  email         String?
  address       String?
  allergies     String?
  medicalNotes  String?
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  appointments  Appointment[]
  consultations Consultation[]
  labTests      LabTest[]
  sales         Sale[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([businessId])
}

model Prescription {
  id                 String   @id @default(cuid())
  prescriptionNumber String   @unique
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorName         String
  dateIssued         DateTime @default(now())
  status             String   @default("PENDING") // PENDING, DISPENSED, CANCELLED
  notes              String?
  instructions       String? // e.g. "Take 1 tablet after meals"
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId             String?  @unique
  sale               Sale?    @relation("PrescriptionSale", fields: [saleId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([businessId])
  @@index([patientId])
}

model Location {
  id            String          @id @default(cuid())
  name          String
  type          String          @default("STORE") // STORE, WAREHOUSE, OUTLET
  address       String?
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stocks        LocationStock[]
  transfersFrom StockTransfer[] @relation("TransfersFrom")
  transfersTo   StockTransfer[] @relation("TransfersTo")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([businessId])
}

model LocationStock {
  id         String   @id @default(cuid())
  locationId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 2)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([locationId, productId])
  @@index([locationId])
  @@index([productId])
}

model StockTransfer {
  id             String   @id @default(cuid())
  fromLocationId String
  toLocationId   String
  productId      String
  quantity       Decimal  @db.Decimal(10, 2)
  status         String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  fromLocation   Location @relation("TransfersFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation     Location @relation("TransfersTo", fields: [toLocationId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([productId])
}

model Appointment {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          User          @relation(fields: [doctorId], references: [id])
  appointmentDate DateTime
  status          String        @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  reason          String?
  notes           String?
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  consultation    Consultation?

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model Consultation {
  id             String       @id @default(cuid())
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         User         @relation(fields: [doctorId], references: [id])
  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  vitals         Json? // { bp, temp, weight, heartRate, etc. }
  chiefComplaint String?
  symptoms       String?
  diagnosis      String?
  treatmentPlan  String?
  doctorNotes    String?      @db.Text
  businessId     String
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId         String?      @unique
  sale           Sale?        @relation("ConsultationSale", fields: [saleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  labTests       LabTest[]

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model LabTest {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          User          @relation("DoctorLabTests", fields: [doctorId], references: [id])
  consultationId  String?
  consultation    Consultation? @relation(fields: [consultationId], references: [id])
  testName        String
  testCategory    String?
  results         String?       @db.Text
  status          String        @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  labTechnicianId String?
  labTechnician   User?         @relation("LabTechnician", fields: [labTechnicianId], references: [id])
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId          String?       @unique
  sale            Sale?         @relation("LabTestSale", fields: [saleId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([businessId])
  @@index([patientId])
  @@index([doctorId])
}

model SalesDraft {
  id            String    @id @default(cuid())
  draftNumber   String    @unique
  businessId    String
  userId        String
  customerId    String?
  customerName  String?   
  customerPhone String?   
  items         Json      
  totalAmount   Decimal   @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([userId])
}
